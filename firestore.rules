rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar que NO lee base de datos, solo verifica el token (GRATIS)
    function hasRole(role) {
      return request.auth != null && request.auth.token[role] == true;
    }

    // Regla para Staff (Cualquiera con rol válido) usando Custom Claims
    function isStaff() {
      return request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.token.cocina == true || 
        request.auth.token.recepcion == true
      );
    }

    match /users/{userId} {
      // El usuario puede leer su propio perfil, o un admin puede leer todo
      allow read: if request.auth != null && (request.auth.uid == userId || hasRole('admin'));
      allow write: if hasRole('admin'); 
    }
    
    match /orders/{orderId} {
      allow read, write: if isStaff();
      match /items/{itemId} { allow read, write: if isStaff(); }
    }

    match /daily_stats/{dateId} {
      allow read: if isStaff();
      // Permitimos escribir solo si es staff para actualizar contadores
      allow write: if isStaff(); 
    }

    match /menuItems/{itemId} {
      allow read: if isStaff();
      allow write: if hasRole('admin') 
                   && request.resource.data.price is number 
                   && request.resource.data.price > 0;
    }
    
    match /configuration/{configId} {
      allow read: if isStaff();
      allow write: if hasRole('admin');
    }
    
    match /counters/{counterId} {
      allow read, write: if isStaff();
    }
    
    match /archived_orders/{orderId} {
       allow read, write: if isStaff();
    }
  }
}