rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return exists(userPath());
    }

    function userRole() {
      return userExists() ? get(userPath()).data.role : null;
    }

    function isAdmin() {
      return userRole() == "admin";
    }

    function isRecepcion() {
      return userRole() == "recepcion";
    }

    function isCocina() {
      return userRole() == "cocina";
    }

    // ---------------- USERS ----------------
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ---------------- ORDERS ----------------
    match /orders/{orderId} {

      // Crear orden (solo recepción)
      allow create: if isRecepcion()
        && request.resource.data.total > 0
        && request.resource.data.items.size() > 0
        && request.resource.data.status == "nueva";

      // Cocina solo puede cambiar status
      allow update: if isCocina()
        && request.resource.data.status in ["preparando", "lista", "entregada"]
        && request.resource.data.diff(resource.data).keys().hasOnly(["status"]);

      // Recepción no puede editar órdenes viejas
      allow update: if isRecepcion()
        && resource.data.status == "nueva"
        && request.resource.data.diff(resource.data).keys().hasOnly(["status"]);

      // Admin sí puede todo
      allow read, update, delete: if isAdmin();

      // Lectura general para cocina y recepción
      allow read: if isRecepcion() || isCocina();
    }

    // ---------------- MENU ----------------
    match /menuItems/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ---------------- CONFIG ----------------
    match /configuration/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ---------------- STATS ----------------
    match /daily_stats/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ---------------- COUNTERS ----------------
    match /counters/{id} {
      allow read: if isAdmin() || isRecepcion() || isCocina();
      allow write: if isAdmin();
    }
  }
}
