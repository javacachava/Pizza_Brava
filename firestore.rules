rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA ---

    // Verifica si el usuario tiene un rol específico (Híbrido: Token O Base de Datos)
    function hasRole(role) {
      return (request.auth.token[role] == true) || 
             (request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role);
    }

    // Verifica si es Staff (Cualquiera de los roles permitidos)
    function isStaff() {
      return isStaffToken() || isStaffDB();
    }

    // A) Chequeo rápido (Token) - Optimización futura
    function isStaffToken() {
      return request.auth.token.role in ['admin', 'cocina', 'recepcion'];
    }

    // B) Chequeo seguro (Base de Datos) - Lo que hará que funcione YA
    function isStaffDB() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'cocina', 'recepcion'];
    }

    // --- REGLAS ---

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || hasRole('admin'));
      allow write: if hasRole('admin'); 
    }
    
    match /orders/{orderId} {
      allow read, write: if isStaff();
      match /items/{itemId} { allow read, write: if isStaff(); }
    }

    match /daily_stats/{dateId} {
      allow read: if isStaff();
      allow write: if isStaff(); 
    }

    match /menuItems/{itemId} {
      allow read: if isStaff(); 
      allow write: if hasRole('admin') 
                   && request.resource.data.price is number 
                   && request.resource.data.price > 0;
    }
    
    match /configuration/{configId} {
      allow read: if isStaff();
      allow write: if hasRole('admin');
    }
    
    match /counters/{counterId} {
      allow read, write: if isStaff();
    }
    
    match /archived_orders/{orderId} {
       allow read, write: if isStaff();
    }
  }
}