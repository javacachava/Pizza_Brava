rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE ACCESO DIRECTO ---
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserActive() {
      // Verifica si existe y si el campo 'active' es true
      let user = getUserData();
      return user != null && user.active == true;
    }

    function hasRole(role) {
      // Verifica si el usuario tiene el rol específico guardado en su documento
      return isUserActive() && getUserData().role == role;
    }
    
    function isStaff() {
      // Cualquiera activo con rol válido es Staff
      return isUserActive() && (getUserData().role in ['recepcion', 'cocina', 'admin']);
    }

    // --- REGLAS SIMPLIFICADAS ---

    // 1. Usuarios: El admin controla todo. El usuario solo se lee a sí mismo.
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || hasRole('admin');
      allow write: if hasRole('admin'); 
    }

    // 2. Contadores (Para generar IDs de órdenes)
    match /counters/{counterId} {
      allow read, write: if isStaff();
    }

    // 3. Órdenes (Cualquier empleado puede trabajar con órdenes)
    match /orders/{orderId} {
      allow read, write: if isStaff();
      
      match /items/{itemId} {
        allow read, write: if isStaff();
      }
    }

    // 4. Menú (Todos leen, solo Admin edita)
    match /menuItems/{itemId} {
      allow read: if isStaff(); 
      allow write: if hasRole('admin');
    }
    
    // 5. Configuración (Igual que el menú)
    match /configuration/{configId} {
      allow read: if isStaff();
      allow write: if hasRole('admin');
    }
  }
}