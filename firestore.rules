rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES AUXILIARES ---
    
    // Verifica que el usuario esté autenticado y su cuenta esté activa
    function isActive() {
      return request.auth != null && 
             request.auth.token.active == true;
    }

    // Verifica roles específicos
    function isAdmin() {
      return isActive() && request.auth.token.role == 'admin';
    }
    
    function isStaff() {
      return isActive() && (request.auth.token.role in ['recepcion', 'cocina', 'admin']);
    }

    // --- REGLAS DE COLECCIONES ---

    // 1. Colección de Usuarios
    match /users/{userId} {
      // ✅ CORREGIDO: El usuario puede leer su propio perfil O un admin puede leer todos
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if isAdmin(); 
    }

    // 2. Contadores (PARA QUE FUNCIONE useOrders)
    match /counters/{counterId} {
      // Necesario para generar el número de orden consecutivo
      allow read, write: if isStaff();
    }

    // 3. Órdenes
    match /orders/{orderId} {
      allow read, write: if isStaff();
      
      match /items/{itemId} {
        allow read, write: if isStaff();
      }
    }

    // 4. Menú
    match /menuItems/{itemId} {
      allow read: if isStaff(); 
      allow write: if isAdmin();
    }
    
    // 5. Configuración
    match /configuration/{configId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
  }
}