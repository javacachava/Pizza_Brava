rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. TU SUPER-PODER (Hardcoded Admin) ---
    // Aquí pegas tu UID real. Esto es infalible.
    function isSuperAdmin() {
      return request.auth.uid == "oK9b8ARXVpZ3gLAqU4swtW6JEl22"; 
    }

    // --- 2. FUNCIONES DE LECTURA DIRECTA ---
    // Esta función va a LEER el documento del usuario en la base de datos
    // para ver si está activo y qué rol tiene.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return request.auth != null && (isSuperAdmin() || getUserData().active == true);
    }

    function isAdmin() {
      return isSuperAdmin() || (isActive() && getUserData().role == 'admin');
    }
    
    function isStaff() {
      return isActive() && (getUserData().role in ['recepcion', 'cocina', 'admin']);
    }

    // --- REGLAS DE COLECCIONES ---

    match /users/{userId} {
      // El admin puede ver todo. El usuario solo su propio perfil.
      allow read: if isSuperAdmin() || request.auth.uid == userId;
      // Solo el admin puede crear/editar/borrar usuarios
      allow write: if isSuperAdmin(); 
    }

    match /counters/{counterId} {
      allow read, write: if isStaff();
    }

    match /orders/{orderId} {
      allow read, write: if isStaff();
      match /items/{itemId} {
        allow read, write: if isStaff();
      }
    }

    match /menuItems/{itemId} {
      allow read: if isStaff(); 
      allow write: if isAdmin();
    }
    
    match /configuration/{configId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
  }
}