rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isStaff() {
      let user = getUserData();
      return user != null && user.active == true && (user.role in ['recepcion', 'cocina', 'admin']);
    }
    function hasRole(role) {
      let user = getUserData();
      return user != null && user.active == true && user.role == role;
    }

    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || hasRole('admin');
      allow write: if hasRole('admin'); 
    }
    
    match /orders/{orderId} {
      allow read, write: if isStaff();
      match /items/{itemId} { allow read, write: if isStaff(); }
    }

    // MEJORA: Validación de tipos de datos para evitar errores en reportes
    match /menuItems/{itemId} {
      allow read: if isStaff();
      allow write: if hasRole('admin') 
                   && request.resource.data.price is number 
                   && request.resource.data.price > 0;
    }
    
    match /configuration/{configId} {
      allow read: if isStaff();
      allow write: if hasRole('admin');
    }
    
    match /counters/{counterId} {
      allow read, write: if isStaff();
    }
    
    match /archived_orders/{orderId} {
       allow read, write: if isStaff(); 
    }
  }
}