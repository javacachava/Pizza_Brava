rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- SAFE HELPERS ---
    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return exists(userDocPath());
    }

    function getUserRole() {
      return userExists() ? get(userDocPath()).data.role : null;
    }

    function hasRole(role) {
      return (request.auth.token[role] == true) ||
             (request.auth != null && getUserRole() == role);
    }

    function isStaffDB() {
      return request.auth != null &&
             (getUserRole() in ['admin','cocina','recepcion']);
    }

    function isStaffToken() {
      return request.auth.token.role in ['admin','cocina','recepcion'];
    }

    function isStaff() {
      return isStaffToken() || isStaffDB();
    }

    // --- RULES ---
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || hasRole('admin'));
      allow write: if hasRole('admin'); 
    }
    
    match /orders/{orderId} {
      allow read, write: if isStaff();
      match /items/{itemId} { allow read, write: if isStaff(); }
    }

    match /daily_stats/{dateId} {
      allow read, write: if isStaff();
    }

    match /menuItems/{itemId} {
      allow read: if isStaff();
      allow write: if hasRole('admin');
    }
    
    match /configuration/{configId} {
      allow read: if isStaff();
      allow write: if hasRole('admin');
    }
    
    match /counters/{counterId} {
      allow read, write: if isStaff();
    }
    
    match /archived_orders/{orderId} {
       allow read, write: if isStaff();
    }
  }
}
